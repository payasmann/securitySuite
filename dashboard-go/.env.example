# Database
DATABASE_URL=postgresql://user:password@localhost:5432/safeguard?sslmode=disable

# Auth
AUTH_SECRET=your-secret-key-here-min-32-chars

# Server
PORT=3000

# Redis (optional, for future pub/sub)
REDIS_URL=redis://localhost:6379

# CORS origin (defaults to http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000

# Central recording ingest (optional)
CENTRAL_INGEST_ENABLED=false
CENTRAL_INGEST_API_KEY=
RECORDINGS_PATH=./central-recordings
