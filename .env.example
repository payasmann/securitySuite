# Database
DATABASE_URL="postgresql://user:password@localhost:5432/infosec?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
AUTH_SECRET=""

# Redis
REDIS_URL="redis://localhost:6379"

# S3 / Cloudflare R2
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_REGION="auto"

# ── Central NVR / Edge Relay Ingest (optional) ───────────────────────────────
# These settings are ONLY needed when this server acts as a central NVR that
# receives recording uploads from remote Edge Relay agents. For standard
# single-site deployments, leave these commented out — no additional routes
# will be registered and existing functionality is unaffected.
#
# CENTRAL_INGEST_ENABLED — Set to "true" to register the recording ingest
# and playback API routes (POST /api/recordings/ingest, GET /api/recordings/...).
# If absent or not "true", these routes return 404.
# CENTRAL_INGEST_ENABLED=true
#
# CENTRAL_INGEST_API_KEY — Shared secret that remote agents must provide in
# the X-API-Key header when uploading segments. Required when ingest is enabled.
# CENTRAL_INGEST_API_KEY=
#
# CENTRAL_STORAGE_PATH — Directory where ingested recording segments are stored.
# Segments are organized as {path}/{schoolId}/{cameraId}/{date}/segment_{time}.mp4
# CENTRAL_STORAGE_PATH=./central-recordings
