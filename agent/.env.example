# Cloud API
API_URL=http://localhost:3000
SCHOOL_ID=your-school-cuid
API_KEY=your-agent-secret-key

# MediaMTX
MEDIAMTX_PATH=/usr/local/bin/mediamtx
MEDIAMTX_CONFIG=./mediamtx.yml

# H.265 → H.264 transcoding (for browser WebRTC compatibility)
# Set to false to pass streams through without re-encoding
TRANSCODE_ENABLED=true
# Set to false to force software encoding even when NVIDIA GPU is present
NVENC_ENABLED=true
# Target video bitrate in kbps (adjust based on resolution and bandwidth)
TRANSCODE_BITRATE=4000

# Local storage
LOCAL_STORAGE_PATH=./recordings
LOCAL_STORAGE_ENABLED=true

# FFmpeg path (used for local recording)
FFMPEG_PATH=ffmpeg
# Recording retention (days)
RETENTION_DAYS=14

# Agent public URL for direct WebRTC (browser connects directly to agent, bypasses cloud)
# Set this to the publicly accessible URL of the agent's MediaMTX WebRTC port (default :8889)
# Example: https://stream.myschool.example.com or http://203.0.113.10:8889
# If not set, browsers will fall back to cloud proxy for video streams
AGENT_PUBLIC_URL=

# Heartbeat interval (ms)
HEARTBEAT_INTERVAL=30000

# Camera config with optional ONVIF credentials
# Format: cameraId:rtspUrl[:onvifUser:onvifPassword]
# ONVIF credentials enable motion event detection from cameras
CAMERAS=CAM-01:rtsp://192.168.1.101:554/stream1:admin:password123,CAM-02:rtsp://192.168.1.102:554/stream1
